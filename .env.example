# =============================================
# Música Surpresa — Variáveis de Ambiente
# =============================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA suba o .env para o repositório (já está no .gitignore).

# Webhook do Google Sheets (Apps Script)
# Usado para registrar leads e formulários na planilha de pedidos.
REACT_APP_GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/SEU_ID_AQUI/exec

# Número de WhatsApp para atendimento (formato internacional, sem +)
# Exemplo: 5511940787078
REACT_APP_WHATSAPP_NUMBER=55119XXXXXXXX
